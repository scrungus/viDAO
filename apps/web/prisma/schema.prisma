generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  VIEWER
  CREATOR
}

enum AttestationType {
  HARDWARE
  SOFTWARE
}

enum PayoutStatus {
  PENDING
  DISTRIBUTED
}

model User {
  id                      String          @id @default(cuid())
  email                   String          @unique
  walletAddress           String?         @unique
  webauthnCredentialId    String?
  webauthnAttestationType AttestationType @default(SOFTWARE)
  subscribedUntil         DateTime?
  role                    UserRole        @default(VIEWER)
  createdAt               DateTime        @default(now())

  videos            Video[]
  watchSessions     WatchSession[]
  monthlyWatchTotals MonthlyWatchTotal[]
  creatorPayouts    CreatorPayout[]
}

model Video {
  id           String   @id @default(cuid())
  creatorId    String
  title        String
  description  String?
  videoPath    String
  thumbnailUrl String?
  createdAt    DateTime @default(now())

  creator       User           @relation(fields: [creatorId], references: [id])
  watchSessions WatchSession[]
}

model WatchSession {
  id              String    @id @default(cuid())
  userId          String
  videoId         String
  startedAt       DateTime  @default(now())
  lastHeartbeatAt DateTime?
  weightedSeconds Int       @default(0)

  user  User  @relation(fields: [userId], references: [id])
  video Video @relation(fields: [videoId], references: [id])
}

model MonthlyWatchTotal {
  userId       String
  month        String   // YYYY-MM format
  weightedHours Decimal @default(0) @db.Decimal(10, 4)

  user User @relation(fields: [userId], references: [id])

  @@id([userId, month])
}

model PayoutPeriod {
  id            String       @id @default(cuid())
  periodStart   DateTime
  periodEnd     DateTime
  totalPoolUsdc Decimal      @db.Decimal(18, 6)
  status        PayoutStatus @default(PENDING)

  creatorPayouts CreatorPayout[]
}

model CreatorPayout {
  id              String  @id @default(cuid())
  payoutPeriodId  String
  creatorId       String
  watchHours      Decimal @db.Decimal(10, 4)
  sharePercentage Decimal @db.Decimal(10, 6)
  usdcAmount      Decimal @db.Decimal(18, 6)
  txHash          String?

  payoutPeriod PayoutPeriod @relation(fields: [payoutPeriodId], references: [id])
  creator      User         @relation(fields: [creatorId], references: [id])
}
